{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.11",
    "@std/expect": "jsr:@std/expect@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  },
  "tasks": {
    "test": "deno task --cwd core test && deno task --cwd cli test",
    "generate": "deno task --cwd core generate"
  },
  "workspace": ["./core", "./cli"],
  "exclude": ["README.md", "README_EN.md"]
}
